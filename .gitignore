# Бинарные файлы (скомпилированные программы и плагины)
*.exe
*.exe~
*.dll
*.so
*.dylib

# Бинарные файлы тестов (создаются через go test -c)
*.test

# Профили покрытия кода и другие артефакты тестов
*.out
coverage.*
*.coverprofile
profile.cov

# Директория зависимостей (раскомментируйте, если используете вендоринг)
# vendor/

# Файлы рабочего пространства Go
go.work
go.work.sum

# Файлы переменных окружения (содержат секреты)
.env

# Настройки популярных IDE
.idea/
.vscode/
*.swp
